,"encoder, _, proj, _ = build_stage3_models(\n","    cfg=cfg_model, device=torch.device(device), ckpt_path=''\n",")\n","\n","assert os.path.exists(CKPT_STAGE3B), f'重みが見つかりません: {CKPT_STAGE3B}'\n","ckpt = torch.load(CKPT_STAGE3B, map_location='cpu', weights_only=False)\n","encoder.load_state_dict(ckpt['student'], strict=False)\n","proj.load_state_dict(ckpt['proj'], strict=False)\n","\n","encoder.eval().to(device)\n","proj.eval().to(device)\n","\n","print(f'Stage 3b best (epoch {ckpt[\"epoch\"]}) ロード完了')\n","print(f'  encoder params: {sum(p.numel() for p in encoder.parameters()):,}')\n","print(f'  proj    params: {sum(p.numel() for p in proj.parameters()):,}')"]},{"cell_type":"markdown","metadata":{"id":"d9lZSwmvM9xK"},"source":["## Step 4 — CLIP テキストエンコーダロード"]},{"cell_type":"code","execution_count":7,"metadata":{"id":"zoxI23egM9xK","executionInfo":{"status":"ok","timestamp":1776847609715,"user_tz":-540,"elapsed":65144,"user":{"displayName":"ko (kita)","userId":"05144123916588878939"}},"colab":{"base_uri":"https://localhost:8080/","height":86,"referenced_widgets":["07cb5f7e3bfa4406b7d8c2e6b0e88b2a","d75dc9d90124419587bd001fc536ed00","a6e94b9967bd4ac2ba20c5d47bad2c1e","1c847fabc2df4370aec625a084960d10","76db7873fc5943c192f61654fb33f67f","b6993efcd3e945348c0615bb13014832","fba0f0b73a3c4905942470928178f0bb","9d8e4913dd8e4a2f9c43b52c481f3cce","89bf7359b44c4f009d56a6cd408eb377","d149bb411ff54efa8fdc8941fb8d71d0","4f4b8c42fdf14db7b146f8edb65226a2"]},"outputId":"7e229d57-4767-4c20-feec-274587440c26"},"outputs":[{"output_type":"stream","name":"stdout","text":["ViT-bigG-14 ロード中... (キャッシュ済みなら高速)\n"]},{"output_type":"display_data","data":{"text/plain":["open_clip_model.safetensors:   0%|          | 0.00/10.2G [00:00<?, ?B/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"07cb5f7e3bfa4406b7d8c2e6b0e88b2a"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["CLIP テキスト次元: 1280 (期待: 1280)  OK\n"]}],"source":["import open_clip\n","\n","print('ViT-bigG-14 ロード中... (キャッシュ済みなら高速)')\n","clip_model, _, _ = open_clip.create_model_and_transforms(\n","    'ViT-bigG-14', pretrained='laion2b_s39b_b160k', device=device\n",")\n","clip_model.eval()\n","tokenizer = open_clip.get_tokenizer('ViT-bigG-14')\n","\n","def encode_texts(texts: list[str]) -> torch.Tensor:\n","    \"\"\"テキストリストを正規化済み CLIP 特徴 (T, 1280) に変換\"\"\"\n","    with torch.no_grad():\n","        toks = tokenizer(texts).to(device)\n","        feats = clip_model.encode_text(toks)\n","        return F.normalize(feats, dim=-1)\n","\n","# 動作確認\n","test = encode_texts(['mandibular condyle'])\n","print(f'CLIP テキスト次元: {test.shape[-1]} (期待: 1280)  OK')"]},{"cell_type":"markdown","metadata":{"id":"zdehj-ViM9xK"},"source":["## Step 5 — 患者選択 & 点群ロード\n","\n","`PAT_ID` を変更して解析する症例を切り替えられます。"]},{"cell_type":"code","execution_count":8,"metadata":{"id":"kPQXB8UGM9xK","executionInfo":{"status":"ok","timestamp":1776847613596,"user_tz":-540,"elapsed":3884,"user":{"displayName":"ko (kita)","userId":"05144123916588878939"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"d66e8309-e87a-4e78-df61-5a0e3b4fbff4"},"outputs":[{"output_type":"stream","name":"stdout","text":["利用可能な患者:\n","  [ 0] Pat 10na_norm\n","  [ 1] Pat 10nb_norm\n","  [ 2] Pat 1a_norm\n","  [ 3] Pat 1b_norm\n","  [ 4] Pat 2a_norm\n","  [ 5] Pat 2b_norm\n","  [ 6] Pat 3a_norm\n","  [ 7] Pat 3b_norm\n","  [ 8] Pat 4a_norm\n","  [ 9] Pat 4b_norm\n","  [10] Pat 5a_norm\n","  [11] Pat 5b_norm\n","  [12] Pat 6a_norm\n","  [13] Pat 6b_norm\n","  [14] Pat 7a_norm\n","  [15] Pat 7b_norm\n","  [16] Pat 8a_norm\n","  [17] Pat 8b_norm\n","  [18] Pat 9na_norm\n","  [19] Pat 9nb_norm\n","\n","選択中: Pat 4b_norm\n"]}],"source":["import json, numpy as np\n","from pathlib import Path\n","from phase3_datasets.dental_dataset import _load_ply, _normalize_unit_sphere, _fps_cpu\n","\n","# ===== 患者選択 =====\n","with open(JSON_PATH, 'r', encoding='utf-8') as f:\n","    candidates = json.load(f)\n","\n","all_patients = sorted(candidates.keys())\n","print('利用可能な患者:')\n","for i, p in enumerate(all_patients):\n","    print(f'  [{i:2d}] {p}')\n","\n","PAT_ID = all_patients[9]   # ← ここを変更 (例: 'Pat 3b_norm')\n","print(f'\\n選択中: {PAT_ID}')"]},{"cell_type":"code","execution_count":9,"metadata":{"id":"BMzEAWVwM9xK","executionInfo":{"status":"ok","timestamp":1776847616622,"user_tz":-540,"elapsed":3026,"user":{"displayName":"ko (kita)","userId":"05144123916588878939"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"12bbd0a0-eb3e-4a05-cece-9ab8a418cf4d"},"outputs":[{"output_type":"stream","name":"stdout","text":["点群: (2048, 3)  座標範囲: [-0.759, 0.718]\n","patch_emb   : torch.Size([1, 384, 128])\n","patch_feat  : torch.Size([1, 128, 1280])\n","patch_centers: torch.Size([1, 3, 128])\n"]}],"source":["# 点群ロード & 前処理\n","ply_path = Path(PLY_DIR) / f'{PAT_ID}.ply'\n","assert ply_path.exists(), f'PLY が見つかりません: {ply_path}'\n","\n","xyz_raw = _load_ply(ply_path)                         # (N_raw, 3)\n","fps_idx = _fps_cpu(xyz_raw, 2048, seed=42)\n","xyz     = xyz_raw[fps_idx]                            # (2048, 3)\n","xyz_n, centroid, scale = _normalize_unit_sphere(xyz)  # 単位球正規化\n","xyz_np  = xyz_n.cpu().numpy()                         # NumPy (2048, 3)\n","\n","pts_t = xyz_n.T.unsqueeze(0).to(device)              # (1, 3, 2048)\n","\n","print(f'点群: {xyz_np.shape}  座標範囲: [{xyz_np.min():.3f}, {xyz_np.max():.3f}]')\n","\n","# パッチ推論\n","with torch.no_grad():\n","    patch_emb, patch_centers, patch_idx = encoder.forward_patches(pts_t)\n","    patch_feat = proj(patch_emb)   # (1, G=128, 1280)\n","\n","centers = patch_centers[0].T.cpu().numpy()  # (128, 3)\n","print(f'patch_emb   : {patch_emb.shape}')\n","print(f'patch_feat  : {patch_feat.shape}')\n","print(f'patch_centers: {patch_centers.shape}')"]},{"cell_type":"markdown","metadata":{"id":"CqkRQzpZM9xK"},"source":["## Step 6 — テキストクエリ設定\n","\n","`TEXT_QUERIES` を自由に編集してください。  \n","`USE_CANDIDATES_TEXTS = True` にすると、candidates.json の代表テキストを自動使用します。"]},{"cell_type":"code","execution_count":10,"metadata":{"id":"Rxu-_JDNM9xK","executionInfo":{"status":"ok","timestamp":1776847616741,"user_tz":-540,"elapsed":114,"user":{"displayName":"ko (kita)","userId":"05144123916588878939"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"3eea61cd-0daa-45fd-9187-616146e11a01"},"outputs":[{"output_type":"stream","name":"stdout","text":["カスタムクエリ 8 件を使用\n","類似度行列: (128, 8)  [-0.282, 0.192]\n"]}],"source":["USE_CANDIDATES_TEXTS = False   # True: candidates.json の texts[0] を使用\n","\n","if USE_CANDIDATES_TEXTS:\n","    patches = candidates[PAT_ID]\n","    TEXT_QUERIES = [p['texts'][0] for p in patches]  # 32 テキスト\n","    print(f'candidates.json から {len(TEXT_QUERIES)} テキストを使用')\n","else:\n","    TEXT_QUERIES = [\n","        'left mandibular condyle',\n","        'right coronoid process',\n","        'left gonial angle',\n","        'right mandibular condyle',\n","        'left condylar neck',\n","        'right mandible body',\n","        'left ramus of mandible',\n","        'rignt mandibular notch',\n","    ]\n","    print(f'カスタムクエリ {len(TEXT_QUERIES)} 件を使用')\n","\n","# CLIP でテキストエンコード\n","text_feats = encode_texts(TEXT_QUERIES)  # (T, 1280)\n","\n","# コサイン類似度スコア計算\n","sim = (patch_feat[0] @ text_feats.T).cpu().numpy()   # (G=128, T)\n","print(f'類似度行列: {sim.shape}  [{sim.min():.3f}, {sim.max():.3f}]')"]},{"cell_type":"markdown","metadata":{"id":"QgSfvthDM9xK"},"source":["## Step 7 — 静止ヒートマップ可視化\n","\n","カラーマップ `coolwarm`: **赤 = 高類似度 / 青 = 低類似度**"]},{"cell_type":"code","execution_count":11,"metadata":{"id":"Ke-JtAAOM9xK","executionInfo":{"status":"ok","timestamp":1776847618450,"user_tz":-540,"elapsed":1685,"user":{"displayName":"ko (kita)","userId":"05144123916588878939"}},"colab":{"base_uri":"https://localhost:8080/","height":0},"outputId":"d7d86d3d-a9a5-45f3-b47d-b32c440b912e"},"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_7031/1226225882.py:39: UserWarning: Glyph 12497 (\\N{KATAKANA