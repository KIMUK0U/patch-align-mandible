_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 12488 (\\N{KATAKANA LETTER TO}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 39006 (\\N{CJK UNIFIED IDEOGRAPH-985E}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 20284 (\\N{CJK UNIFIED IDEOGRAPH-4F3C}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 24230 (\\N{CJK UNIFIED IDEOGRAPH-5EA6}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 36196 (\\N{CJK UNIFIED IDEOGRAPH-8D64}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 39640 (\\N{CJK UNIFIED IDEOGRAPH-9AD8}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 38738 (\\N{CJK UNIFIED IDEOGRAPH-9752}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 20302 (\\N{CJK UNIFIED IDEOGRAPH-4F4E}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x700 with 16 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["保存: /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results/Pat 4b_norm_heatmap_static.png\n"]}],"source":["import matplotlib.pyplot as plt\n","\n","n_queries = len(TEXT_QUERIES)\n","ncols = min(4, n_queries)\n","nrows = (n_queries + ncols - 1) // ncols\n","\n","fig, axes = plt.subplots(nrows, ncols,\n","                          figsize=(ncols * 3.5, nrows * 3.5),\n","                          facecolor='white')\n","axes = np.array(axes).reshape(-1)  # 1D 配列に統一\n","\n","for i, (ax, query) in enumerate(zip(axes, TEXT_QUERIES)):\n","    sim_q = sim[:, i]\n","\n","    # 背景点群\n","    ax.scatter(xyz_np[:, 0], xyz_np[:, 2],\n","               c='lightgray', s=0.5, alpha=0.4, linewidths=0)\n","\n","    # パッチ中心 (coolwarm: 赤=高, 青=低)\n","    sc = ax.scatter(centers[:, 0], centers[:, 2],\n","                    c=sim_q, cmap='coolwarm', s=30,\n","                    vmin=sim_q.min(), vmax=sim_q.max(),\n","                    linewidths=0)\n","    plt.colorbar(sc, ax=ax, fraction=0.04, pad=0.02)\n","\n","    short = query[:35] + ('...' if len(query) > 35 else '')\n","    ax.set_title(short, fontsize=7, pad=3)\n","    ax.set_xlim(-1.3, 1.3)\n","    ax.set_ylim(-1.3, 1.3)\n","    ax.set_aspect('equal')\n","    ax.axis('off')\n","\n","# 余ったサブプロットを非表示\n","for ax in axes[n_queries:]:\n","    ax.set_visible(False)\n","\n","fig.suptitle(f'{PAT_ID} — パッチ‑テキスト類似度 (coolwarm: 赤=高 / 青=低)',\n","             fontsize=10, y=1.01)\n","plt.tight_layout()\n","\n","save_path = os.path.join(OUT_DIR, f'{PAT_ID}_heatmap_static.png')\n","plt.savefig(save_path, dpi=120, bbox_inches='tight')\n","plt.show()\n","print(f'保存: {save_path}')"]},{"cell_type":"markdown","metadata":{"id":"4RTz1X0VM9xK"},"source":["## Step 8 — z 軸回転 GIF 生成\n","\n","各テキストクエリについて、点群を z 軸周りに 10° ずつ回転させた GIF を保存する。"]},{"cell_type":"code","execution_count":12,"metadata":{"id":"Ephk11c_M9xL","executionInfo":{"status":"ok","timestamp":1776847663654,"user_tz":-540,"elapsed":45202,"user":{"displayName":"ko (kita)","userId":"05144123916588878939"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"cd7f3692-679e-43e1-e1aa-b99fe34c0e29"},"outputs":[{"output_type":"stream","name":"stdout","text":["GIF 生成: 8 クエリ × 36 フレーム (10°/frame, 8 fps)\n","  [ 1/8] /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results/Pat 4b_norm_00_left_mandibular_condyle.gif\n","  [ 2/8] /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results/Pat 4b_norm_01_right_coronoid_process.gif\n","  [ 3/8] /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results/Pat 4b_norm_02_left_gonial_angle.gif\n","  [ 4/8] /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results/Pat 4b_norm_03_right_mandibular_condyle.gif\n","  [ 5/8] /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results/Pat 4b_norm_04_left_condylar_neck.gif\n","  [ 6/8] /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results/Pat 4b_norm_05_right_mandible_body.gif\n","  [ 7/8] /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results/Pat 4b_norm_06_left_ramus_of_mandible.gif\n","  [ 8/8] /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results/Pat 4b_norm_07_rignt_mandibular_notch.gif\n","\n","完了: 8 件の GIF を /content/drive/MyDrive/2026研究/ULIP_PointLLM/DentalPatchAligned3D/Phase3_Training/inference_results に保存\n"]}],"source":["import imageio.v2 as imageio\n","import io\n","\n","def rotate_z(xyz: np.ndarray, theta_deg: float) -> np.ndarray:\n","    \"\"\"z 軸周りに theta_deg 度回転\"\"\"\n","    theta = np.radians(theta_deg)\n","    c, s = np.cos(theta), np.sin(theta)\n","    R = np.array([[c, -s, 0], [s, c, 0], [0, 0, 1]], dtype=np.float32)\n","    return xyz @ R.T\n","\n","\n","DEGREES_PER_FRAME = 10\n","N_FRAMES          = 360 // DEGREES_PER_FRAME   # 36 フレーム\n","FPS               = 8\n","\n","print(f'GIF 生成: {n_queries} クエリ × {N_FRAMES} フレーム (10°/frame, {FPS} fps)')\n","\n","gif_paths = []\n","for qi, query in enumerate(TEXT_QUERIES):\n","    sim_q = sim[:, qi]\n","    vmin, vmax = float(sim_q.min()), float(sim_q.max())\n","\n","    frames = []\n","    for angle in range(0, 360, DEGREES_PER_FRAME):\n","        xyz_rot     = rotate_z(xyz_np, angle)\n","        centers_rot = rotate_z(centers, angle)\n","\n","        fig, ax = plt.subplots(figsize=(4, 4), facecolor='white')\n","\n","        ax.scatter(xyz_rot[:, 0], xyz_rot[:, 2],\n","                   c='lightgray', s=0.5, alpha=0.4, linewidths=0)\n","\n","        sc = ax.scatter(centers_rot[:, 0], centers_rot[:, 2],\n","                        c=sim_q, cmap='coolwarm', s=30,\n","                        vmin=vmin, vmax=vmax, linewidths=0)\n","\n","        plt.colorbar(sc, ax=ax, fraction=0.04, pad=0.02)\n","\n","        short = query[:30] + ('...' if len(query) > 30 else '')\n","        ax.set_title(f'{short}\\n{angle:3d}°', fontsize=7, pad=3)\n","        ax.set_xlim(-1.3, 1.3)\n","        ax.set_ylim(-1.3, 1.3)\n","        ax.set_aspect('equal')\n","        ax.axis('off')\n","        plt.tight_layout(pad=0.4)\n","\n","        buf = io.BytesIO()\n","        plt.savefig(buf, format='png', dpi=90, bbox_inches='tight')\n","        buf.seek(0)\n","        frames.append(imageio.imread(buf))\n","        plt.close(fig)\n","\n","    # フレームサイズを統一\n","    h = min(f.shape[0] for f in frames)\n","    w = min(f.shape[1] for f in frames)\n","    frames = [f[:h, :w] for f in frames]\n","\n","    safe_name = query.replace(' ', '_').replace('/', '-')[:40]\n","    gif_path  = os.path.join(OUT_DIR, f'{PAT_ID}_{qi:02d}_{safe_name}.gif')\n","    imageio.mimsave(gif_path, frames, fps=FPS, loop=0)\n","    gif_paths.append(gif_path)\n","    print(f'  [{qi+1:2d}/{n_queries}] {gif_path}')\n","\n","print(f'\\n完了: {len(gif_paths)} 件の GIF を {OUT_DIR} に保存')"]},{"cell_type":"markdown","metadata":{"id":"RKzidrg-M9xL"},"source":["## Step 9 — 複数患者の一括処理 (オプション)\n","\n","全患者に対して静止ヒートマップと GIF を生成する。"]},{"cell_type":"code","execution_count":13,"metadata":{"id":"ywwOfhNpM9xL","executionInfo":{"status":"ok","timestamp":1776847663662,"user_tz":-540,"elapsed":6,"user":{"displayName":"ko (kita)","userId":"05144123916588878939"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"7bf9014d-7489-4545-de15-1d7016c4a8fe"},"outputs":[{"output_type":"stream","name":"stdout","text":["RUN_ALL = False のためスキップ (True に変更すると全患者処理)\n"]}],"source":["RUN_ALL = False   # True にすると全患者を処理\n","\n","if RUN_ALL:\n","    for pat_id in all_patients:\n","        ply_path = Path(PLY_DIR) / f'{pat_id}.ply'\n","        if not ply_path.exists():\n","            print(f'スキップ (PLY なし): {pat_id}')\n","            continue\n","\n","        # 点群ロード & 推論\n","        xyz_raw = _load_ply(ply_path)\n","        fps_idx = _fps_cpu(xyz_raw, 2048, seed=42)\n","        xyz     = xyz_raw[fps_idx]\n","        xyz_n, _, _ = _normalize_unit_sphere(xyz)\n","        xyz_np_i = xyz_n.cpu().numpy()\n","        pts_t_i  = xyz_n.T.unsqueeze(0).to(device)\n","\n","        with torch.no_grad():\n","            pe, pc, pi = encoder.forward_patches(pts_t_i)\n","            pf = proj(pe)\n","\n","        centers_i = pc[0].T.cpu().numpy()\n","        sim_i = (pf[0] @ text_feats.T).cpu().numpy()\n","\n","        # 静止ヒートマップ\n","        ncols_i = min(4, len(TEXT_QUERIES))\n","        nrows_i = (len(TEXT_QUERIES) + ncols_i - 1) // ncols_i\n","        fig, axes_i = plt.subplots(nrows_i, ncols_i,\n","                                    figsize=(ncols_i * 3, nrows_i * 3))\n","        axes_i = np.array(axes_i).reshape(-1)\n","        for qi, (ax, q) in enumerate(zip(axes_i, TEXT_QUERIES)):\n","            sq = sim_i[:, qi]\n","            ax.scatter(xyz_np_i[:, 0], xyz_np_i[:, 2],\n","                       c='lightgray', s=0.3, alpha=0.4, linewidths=0)\n","            sc = ax.scatter(centers_i[:, 0], centers_i[:, 2],\n","                            c=sq, cmap='coolwarm', s=20,\n","                            vmin=sq.min(), vmax=sq.max(), linewidths=0)\n","            ax.set_title(q[:25], fontsize=6)\n","            ax.set_aspect('equal'); ax.axis('off')\n","        for ax in axes_i[len(TEXT_QUERIES):]:\n","            ax.set_visible(False)\n","        fig.suptitle(pat_id, fontsize=9)\n","        plt.tight_layout()\n","        sp = os.path.join(OUT_DIR, f'{pat_id}_heatmap_static.png')\n","        plt.savefig(sp, dpi=100, bbox_inches='tight')\n","        plt.close()\n","        print(f'[{pat_id}] 静止ヒートマップ保存: {sp}')\n","\n","    print('全患者処理完了')\n","else:\n","    print('RUN_ALL = False のためスキップ (True に変更すると全患者処理)')"]}],"metadata":{"accelerator":"GPU","colab":{"gpuType":"L4","provenance":[],"machine_shape":"hm"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.10.0"},"widgets":{"application/vnd.jupyter.widget-state+json":{"07cb5f7e3bfa4406b7d8c2e6b0e88b2a":{"model_module":"@jupyter-widgets/controls","model_name":"HBoxModel","model_module_version":"1.5.0","state":{"_dom_classes":[],"_model_module":"@jupyter-widgets/controls","_model_module_version":"1.5.0","_model_name":"HBoxModel","_view_count":null,"_view_module":"@jupyter-widgets/controls","_view_module_version":"1.5.0","_view_name":"HBoxView","box_style":"","children":["IPY_MODEL_d75dc9d90124419587bd001fc536ed00","IPY_MODEL_a6e94b9967bd4ac2ba20c5d47bad2c1e","IPY_MODEL_1c847fabc2df4370aec625a084960d10"],"layout":"IPY_MODEL_76db7873fc5943c192f61654fb33f67f"}},"d75dc9d90124419587bd001fc536ed00":{"model_module":"@jupyter-widgets/controls","model_name":"HTMLModel","model_module_version":"1.5.0","state":{"_dom_classes":[],"_model_module":"@jupyter-widgets/controls","_model_module_version":"1.5.0","_model_name":"HTMLModel","_view_count":null,"_view_module":"@jupyter-widgets/controls","_view_module_version":"1.5.0","_view_name":"HTMLView","description":"","description_tooltip":null,"layout":"IPY_MODEL_b6993efcd3e945348c0615